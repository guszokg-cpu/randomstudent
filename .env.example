NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# If your Supabase project shows a publishable key instead of an anon key,
# you can use this name instead. Keep only one of the two key variables filled.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Hidden teacher account used by the password-only login screen.
# Create this same email as a Supabase Auth user and set its password there.
NEXT_PUBLIC_TEACHER_LOGIN_EMAIL=

# Optional server-only key for future admin/server jobs.
# Do not prefix this with NEXT_PUBLIC and do not expose it in client code.
# SUPABASE_SERVICE_ROLE_KEY=
